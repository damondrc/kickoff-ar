<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     widget_preview.xml
     ============================================================
     Lo que se ve en el SELECTOR de widgets (Android 12+ usa
     android:previewLayout). Reproduce el aspecto real del widget
     en su estado más representativo: próximo partido programado.

     No es Glance: el selector necesita un layout RemoteViews
     clásico, por eso está hecho con LinearLayout/TextView.
     ============================================================ -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="220dp"
    android:layout_height="70dp"
    android:background="@drawable/widget_preview_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_preview_ball" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="RIV vs CAT"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_preview_ball" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="dom 26 jul · 16:00"
        android:textColor="#B0BEC5"
        android:textSize="12sp" />
</LinearLayout>
