<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
  next_match_widget_info.xml
  ============================================================
  Metadatos del widget (lo que Android lee del Manifest).

  CLAVES:
  - updatePeriodMillis="0": Android NO actualiza el widget
    periódicamente. Toda actualización la maneja nuestro
    MatchSyncWorker (la filosofía "solo cuando hace falta").
  - configure: la Activity que se abre al agregar el widget
    para elegir el equipo (obligatoria).
  - initialLayout: layout de "cargando" que provee Glance.
  ============================================================ -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/widget_description"
    android:minWidth="180dp"
    android:minHeight="60dp"
    android:targetCellWidth="3"
    android:targetCellHeight="1"
    android:resizeMode="horizontal|vertical"
    android:updatePeriodMillis="0"
    android:widgetCategory="home_screen"
    android:configure="com.futbolarg.futbolargentinowidgets.widget.config.WidgetConfigActivity"
    android:previewLayout="@layout/widget_preview"
    android:initialLayout="@layout/widget_initial" />
